# LLM Provider: "anthropic" or "openai-compatible"
CIVICPULSE_PROVIDER=anthropic

# Anthropic (used when CIVICPULSE_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible (used when CIVICPULSE_PROVIDER=openai-compatible)
# CIVICPULSE_API_KEY=sk-...
# CIVICPULSE_BASE_URL=https://api.openai.com/v1

# Model selection
CIVICPULSE_MODEL=claude-haiku-4-5-20251001
CIVICPULSE_FILTER_MODEL=claude-haiku-4-5-20251001  # Defaults to CIVICPULSE_MODEL if unset

# Retrieval
CIVICPULSE_TOP_N=5          # Number of chunks returned by BM25 search
CIVICPULSE_VAULT_PATH=./vault  # Path to the knowledge vault directory

# Expanded corpus sources
CIVICPULSE_YOUTUBE_API_KEY=your-youtube-data-api-key
CIVICPULSE_ECODE_CUSTOMER=BA0924
CIVICPULSE_ECODE_API_KEY=your-ecode360-api-key
CIVICPULSE_ECODE_API_SECRET=your-ecode360-api-secret
